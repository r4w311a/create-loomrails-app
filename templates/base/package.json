{
  "name": "loomrails-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "description": "LoomRails polyglot monorepo",
  "scripts": {
    "api:openapi": "pnpm --dir apps/api openapi:generate",
    "api:client": "pnpm --filter @loomrails/types generate",
    "api:types": "pnpm api:openapi && pnpm api:client",
    "dev": "pnpm api:types && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "pnpm --dir apps/api test"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  }
}
